# --- SERVER CONFIGURATION ---
PORT=5000 # The port on which the Express server will run

# --- DATABASE ---
MONGO_URI=mongodb://localhost:27017/sk_sports # Your MongoDB connection string (Local or MongoDB Atlas)

# --- SECURITY ---
JWT_SECRET=your_jwt_secret_key_here # A long random string for signing JSON Web Tokens

# --- CORS / ORIGINS ---
# These URLs are used to allow cross-origin requests from your frontend and admin panel
FRONTEND_URL=http://localhost:5173 # URL of your React client application
ADMIN_URL=http://localhost:5175    # URL of your Admin Panel application

# --- ADMIN INITIAL CREDENTIALS ---
# Used for the first-time admin setup or environment-based auth checks
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin_password_123

# --- RAZORPAY PAYMENT GATEWAY ---
# Get these from your Razorpay Dashboard (Settings > API Keys)
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_SECRET=your_razorpay_secret_key

# --- CLOUDINARY (MEDIA STORAGE) ---
# Used for uploading product images
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# --- SHIPROCKET (SHIPPING) ---
# Used for integration with shipping service
SHIPROCKET_EMAIL=your_shiprocket_email
SHIPROCKET_PASSWORD=your_shiprocket_password
